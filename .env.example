GEMINI_API_KEY=your-gemini-api-key-here

IMAGE_MODEL=gemini-2.5-flash-image
ASPECT_RATIO=9:16

# Which video provider to use: "veo" | "higgsfield" | "fal" | "kling"
VIDEO_PROVIDER=fal

# --- Veo (via Gemini API, 10 RPD limit on Tier 1) ---
# Constraint: 1080p requires duration=8. 720p allows 4/6/8.
VEO_MODEL=veo-3.1-fast-generate-preview
VEO_RESOLUTION=720p
VEO_SCENE_DURATION=8
VEO_TRANSITION_DURATION=8

# --- Higgsfield DoP (cloud.higgsfield.ai, long queue on free plan) ---
# tier: lite (~$0.125/clip) | turbo ($0.406) | standard ($0.563)
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
HIGGSFIELD_TIER=lite

# --- fal.ai (pay-as-you-go, no RPD caps — recommended default) ---
# FAL_KEY format is "key_id:secret" from https://fal.ai/dashboard/keys
# Cheapest FLF models:
#   fal-ai/kling-video/o1/standard/image-to-video   $0.084/s 720p
#   fal-ai/kling-video/o1/pro/image-to-video        ~$0.168/s 1080p
#   fal-ai/wan-flf2v                                $0.08/s 720p
FAL_KEY=
# Kling 2.6 Pro audio: $0.14/s (audio OR FLF, not both)
# Kling V3 Pro FLF+audio: fal-ai/kling-video/v3/pro/image-to-video ($0.168/s)
FAL_APP=fal-ai/kling-video/v3/pro/image-to-video
FAL_DURATION=5
FAL_FIRST_PARAM=start_image_url
FAL_LAST_PARAM=end_image_url
# "true" | "false" | "" (let model use its default)
FAL_GENERATE_AUDIO=true

# --- Kling official API (api.klingai.com, JWT auth, cheapest Kling V3 route) ---
# Register at https://app.klingai.com/global/dev, deposit min $10-20
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_MODEL=kling-v3
KLING_MODE=pro
KLING_DURATION=5
KLING_ENABLE_AUDIO=true
